    <script>
      var codeLines = [];
      codeLines.push('');codeLines.push('package main\u000A');codeLines.push('import (\u000A    \"context\"\u000A    \"fmt\"\u000A    \"os/signal\"\u000A    \"syscall\"\u000A)\u000A');codeLines.push('func main() {\u000A');codeLines.push('    ctx, stop :\u003D signal.NotifyContext(\u000A        context.Background(), syscall.SIGINT, syscall.SIGTERM)\u000A    defer stop()\u000A');codeLines.push('    fmt.Println(\"awaiting signal\")\u000A    \u003C-ctx.Done()\u000A');codeLines.push('    fmt.Println()\u000A    fmt.Println(context.Cause(ctx))\u000A    fmt.Println(\"exiting\")\u000A}\u000A');codeLines.push('');
    </script>
