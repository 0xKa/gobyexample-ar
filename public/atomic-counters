  </head>
  <script>
      window.onkeydown = (e) => {
          if (e.ctrlKey || e.altKey || e.shiftKey || e.metaKey) {
              return;
          }
          
          if (e.key == "ArrowRight") {
              window.location.href = 'rate-limiting';
          }
          
          
          if (e.key == "ArrowLeft") {
