          <td class="docs">
            
          </td>
          <td class="code leading">
            <a href="https://go.dev/play/p/pikUg0tMGBE" class="run" title="شغّل الكود" aria-label="شغّل الكود في Go Playground"><img src="play.png" alt="" /></a><button type="button" class="copy" title="انسخ الكود" aria-label="انسخ الكود"><img src="clipboard.png" alt="" /></button>
